async function getAIRecommendation(user) {
  const res = await fetch("https://generativelanguage.googleapis.com/v1beta/models/gemini-pro:generateContent?key=YOUR_API_KEY", {
    method: "POST",
    headers: {"Content-Type": "application/json"},
    body: JSON.stringify({
      contents: [{
        parts: [{
          text: `Suggest scholarships for ${JSON.stringify(user)}`
        }]
      }]
    })
  });

  const data = await res.json();
  return data;
}
