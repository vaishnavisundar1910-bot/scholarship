body {
  font-family: Arial;
  background: #f5f5f5;
  text-align: center;
}

input {
  margin: 5px;
  padding: 8px;
}

button {
  padding: 10px;
  background: green;
  color: white;
  border: none;
  cursor: pointer;
}

.card {
  background: white;
  padding: 15px;
  margin: 10px;
  border-radius: 10px;
  box-shadow: 0 0 10px #ccc;
}
