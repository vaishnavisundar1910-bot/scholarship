<!DOCTYPE html>
<html>
<head>
  <title>Scholarship Finder</title>
  <link rel="stylesheet" href="style.css">
</head>
<body>

<h1 id="title">Scholarship Finder</h1>

<select onchange="changeLang(this.value)">
  <option value="en">English</option>
  <option value="ta">Tamil</option>
  <option value="hi">Hindi</option>
</select>

<h2>Enter Details</h2>

<input id="gender" placeholder="Gender"><br>
<input id="income" placeholder="Income"><br>
<input id="state" placeholder="State"><br>

<button onclick="check()">Check Scholarships</button>

<h2>Eligible</h2>
<div id="eligible"></div>

<h2>Others</h2>
<div id="others"></div>

<script src="data.js"></script>
<script src="lang.js"></script>
<script src="script.js"></script>

</body>
</html>
